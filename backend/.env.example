# Backend Configuration

# Server
PORT=8080
HOST=0.0.0.0

# Redis
REDIS_URL=redis://127.0.0.1:6379
REDIS_CACHE_TTL=300

# MongoDB
MONGODB_URL=mongodb://127.0.0.1:27017
MONGODB_DATABASE=omni

# Historical Data Backfill (days)
BACKFILL_DAYS=30

# Aave Subgraph IDs (The Graph Studio)
AAVE_SUBGRAPH_ARBITRUM=your-subgraph-id
AAVE_SUBGRAPH_BASE=your-subgraph-id

# Kamino API
KAMINO_API_URL=https://api.kamino.finance

# Morpho API
MORPHO_API_URL=https://api.morpho.org/graphql

# Fluid API
FLUID_API_URL=https://api.fluid.instadapp.io

# Optional: TronGrid API Key (for JustLend)
# TRONGRID_API_KEY=

# Optional: The Graph Studio API Key (for Aave historical data)
# THE_GRAPH_API_KEY=

# CORS (comma-separated origins, e.g. http://localhost:5173,https://app.example.com)
CORS_ORIGINS=http://localhost:5173

# Logging
RUST_LOG=info,omni_backend=debug
